{
  "name": "vector-edit-gym",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "VectorEditGym: a preservation-aware benchmark for naturalistic SVG repair.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yug-space/vector-edit-gym.git"
  },
  "homepage": "https://www.vecbench.xyz",
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "next": "16.2.10"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "scripts": {
    "corpus:verify": "node scripts/humanize-instructions.mjs",
    "test:sdk": "python -m pytest sdk/python/tests -q",
    "benchmark:dry-run": "python scripts/benchmark-openrouter.py --dry-run",
    "benchmark:merge": "python scripts/merge-runs.py",
    "benchmark:rescore": "python scripts/rescore-results.py",
    "publish:model-results": "node scripts/publish-model-results.mjs",
    "traces:verify": "node scripts/verify-published-traces.mjs",
    "viewer:prepare": "node scripts/prepare-viewer-data.mjs",
    "viewer:lint": "npm --prefix viewer run lint",
    "viewer:dev": "npm run viewer:prepare && npm --prefix viewer run dev",
    "viewer:build": "npm run viewer:prepare && npm --prefix viewer run build",
    "viewer:start": "npm --prefix viewer start",
    "generate:harbor": "node scripts/generate-harbor.mjs"
  }
}
